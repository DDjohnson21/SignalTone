# ── LLM Provider ──────────────────────────────────────────────────────────────
# "openai" or "anthropic" (default: anthropic)
LLM_PROVIDER=anthropic

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Model to use when LLM_PROVIDER=openai (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model to use when LLM_PROVIDER=anthropic (default: claude-opus-4-6)
ANTHROPIC_MODEL=claude-opus-4-6

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# Raises GitHub API rate limit from 60 → 5000 req/hr
GITHUB_TOKEN=your_github_token_here

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
